{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "opencode",
  "plugin": [
    "./plugins/subagent-banner.tsx",
    "./plugins/terminal-title.tsx"
  ],
  "keybinds": {
    "session_interrupt": "ctrl+c,escape",
    "session_fork": "<leader>f",
    "input_clear": "ctrl+u",
    "app_exit": "ctrl+d,<leader>q",
    "messages_line_up": "ctrl+alt+y,ctrl+k",
    "messages_line_down": "ctrl+alt+e",
    "input_newline": "shift+return,ctrl+return,ctrl+j",
    "input_delete_to_line_end": "none"
  }
}