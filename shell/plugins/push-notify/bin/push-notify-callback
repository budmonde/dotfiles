#!/usr/bin/env bash
# Callback script invoked by Windows protocol handler when notification is clicked.
# Usage: notify-callback <url>
# URL format: wsltoast://focus?pane=%2557

set -e

url="$1"
if [[ -z "$url" ]]; then
    exit 0
fi

pane=""
if [[ "$url" =~ pane=([^&]+) ]]; then
    pane="${BASH_REMATCH[1]}"
    pane=$(printf '%b' "${pane//%/\\x}")
fi

if [[ -n "$pane" ]]; then
    tmux select-window -t "$pane" 2>/dev/null || true
    tmux select-pane -t "$pane" 2>/dev/null || true
fi
