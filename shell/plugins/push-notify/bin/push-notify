#!/usr/bin/env bash
# Cross-platform notification script
# Usage: push-notify [OPTIONS] <title> <message>
#
# Options:
#   --sound <name>    Play specific sound (platform-dependent)
#   --pane <id>       Focus this tmux pane when clicked (WSL only)
#   --silent          No sound at all

set -e

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
BACKENDS_DIR="$SCRIPT_DIR/../backends"

sound=""
pane=""
silent=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --sound)
            sound="$2"
            shift 2
            ;;
        --pane)
            pane="$2"
            shift 2
            ;;
        --silent)
            silent=true
            shift
            ;;
        -*)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

title="${1:-Notification}"
message="${2:-Task finished}"

detect_backend() {
    if [[ -n "$IS_WSL" ]]; then
        echo "wsl"
    elif [[ -n "$IS_MACOS" ]]; then
        echo "macos"
    else
        echo "linux"
    fi
}

backend=$(detect_backend)
backend_script="$BACKENDS_DIR/$backend.sh"

if [[ ! -f "$backend_script" ]]; then
    echo "Error: Backend not found: $backend_script" >&2
    exit 1
fi

source "$backend_script"
send_notification "$title" "$message" "$sound" "$pane" "$silent"
