#!/usr/bin/env bash
# Cross-platform notification script
# Usage: push-notify [OPTIONS] <title> <message>
#
# Options:
#   --sound <name>    Play specific sound (platform-dependent)
#   --silent          No sound at all
#
# On WSL, delegates to the Windows push-notify.cmd.
# macOS/Linux support is not yet implemented.

set -e

sound=""
silent=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --sound)
            sound="$2"
            shift 2
            ;;
        --pane)
            shift 2
            ;;
        --silent)
            silent=true
            shift
            ;;
        -*)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

title="${1:-Notification}"
message="${2:-Task finished}"

if [[ -n "${WSL_DISTRO_NAME:-}" ]]; then
    args=()
    if [[ -n "$sound" ]]; then
        args+=(--sound "$sound")
    fi
    if [[ "$silent" == true ]]; then
        args+=(--silent)
    fi
    args+=("$title" "$message")
    cmd.exe /C push-notify "${args[@]}" > /dev/null 2>&1
else
    echo "push-notify: no backend available for this platform" >&2
    exit 1
fi
