#!/usr/bin/env bash
# push-notify installation script
# Links the push-notify binary into ~/.local/bin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="$HOME/.local/bin"

mkdir -p "$BIN_DIR"

ln -sf "$SCRIPT_DIR/bin/push-notify" "$BIN_DIR/push-notify"
echo "Linked push-notify to $BIN_DIR"
