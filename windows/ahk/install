#!/usr/bin/env bash
set -euo pipefail

# Only run on WSL
if [ -z "${WSL_DISTRO_NAME:-}" ]; then
    echo "Skipping AHK install (not WSL)."
    exit 0
fi

# Get Windows home directory
WINDOWS_USER=$(powershell.exe -NoProfile -Command "[Environment]::UserName" | tr -d '\r\n')
WINDOWS_HOME="/mnt/c/Users/$WINDOWS_USER"
STARTUP_DIR="$WINDOWS_HOME/AppData/Roaming/Microsoft/Windows/Start Menu/Programs/Startup"

# Create startup directory if needed
mkdir -p "$STARTUP_DIR"

# Get the directory where this script lives
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Copy the script (symlinks don't work across WSL/Windows boundary)
cp "$SCRIPT_DIR/startup.ahk" "$STARTUP_DIR/startup.ahk"

echo "Copied startup.ahk to Windows Startup folder."
