#!/usr/bin/env bash
# Set the terminal window title via OSC 0.
# Usage: set-title <title>
#
# Emits when stdout is a tty and $TERM claims OSC support. Terminals
# without an OSC parser (TERM=dumb, TERM=linux) silently ignore the
# sequence, so gating on $TERM avoids visible garbage on those. tmux
# is handled explicitly via a DCS pass-through so the title reaches
# the outer terminal, not just tmux's own status line.

set -e

title="${1:-}"
if [[ -z "$title" ]]; then
    echo "Usage: set-title <title>" >&2
    exit 1
fi

[[ -t 1 ]] || exit 0

case "$TERM" in
    xterm*|screen*|tmux*|alacritty*|kitty*|ghostty*|wezterm*|rxvt*|vte*)
        if [[ -n "$TMUX" ]]; then
            printf '\033Ptmux;\033\033]0;%s\007\033\\' "$title"
        else
            printf '\033]0;%s\007' "$title"
        fi
        ;;
esac
